# =============================================================================
# AgentOS Docs .gitignore
# 版本: 1.0.0
# 最后更新: 2026-05-04
# 用途: 排除构建产物、依赖目录、环境配置文件及本地开发临时文件
# 模块定位: AgentOS文档中心，不包含源代码
# 所有权: SPHARX Ltd
# =============================================================================

# -----------------------------------------------------------------------------
# Documentation build output
# -----------------------------------------------------------------------------
_build/
_site/
html/
site/
dist/
build/
.sphinx/
.doctrees/

# -----------------------------------------------------------------------------
# Generated documentation
# -----------------------------------------------------------------------------
*.pdf
*.epub
*.mobi
*.dvi

# -----------------------------------------------------------------------------
# Diagrams and images (generated)
# -----------------------------------------------------------------------------
*.svg.bak
*.png.bak
diagrams/output/

# -----------------------------------------------------------------------------
# Dependencies (if docs use any tools)
# -----------------------------------------------------------------------------
node_modules/
.pnpm-store/
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/

# -----------------------------------------------------------------------------
# Environment (sensitive)
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local

# -----------------------------------------------------------------------------
# IDE and Editor
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# -----------------------------------------------------------------------------
# OS files
# -----------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
._*
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
logs/

# -----------------------------------------------------------------------------
# Temp files
# -----------------------------------------------------------------------------
tmp/
temp/
*.tmp
*.temp
*.bak
*.backup
*.draft
*.notes
DRAFT*
NOTES*
TODO*
