# Part of Airymax open-source project
# =============================================================================

# -----------------------------------------------------------------------------
# Documentation build output
# -----------------------------------------------------------------------------
_build/
_site/
html/
site/
dist/
build/
.sphinx/
.doctrees/

# -----------------------------------------------------------------------------
# Generated documentation
# -----------------------------------------------------------------------------
*.pdf
*.epub
*.mobi
*.dvi

# -----------------------------------------------------------------------------
# Diagrams and images (generated)
# -----------------------------------------------------------------------------
*.svg.bak
*.png.bak
diagrams/output/

# -----------------------------------------------------------------------------
# Dependencies (if docs use any tools)
# -----------------------------------------------------------------------------
node_modules/
.pnpm-store/
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/

# -----------------------------------------------------------------------------
# Environment (sensitive)
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local

# -----------------------------------------------------------------------------
# IDE and Editor
# -----------------------------------------------------------------------------
.vscode/
.idea/
.trae/
*.swp
*.swo
*~
.project
.classpath
.settings/

# -----------------------------------------------------------------------------
# OS files
# -----------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
._*
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
logs/

# -----------------------------------------------------------------------------
# Temp files
# -----------------------------------------------------------------------------
tmp/
temp/
*.tmp
*.temp
*.bak
*.backup
*.draft
*.notes
DRAFT*
NOTES*
TODO*
